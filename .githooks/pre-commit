#!/usr/bin/perl
use strict;
use warnings;

# Git pre-commit hook for FODS files
# Cleans office:meta, handles view-settings changes, and clears style:region-right

# Get list of staged .fods files
sub get_staged_fods_files {
    my @files;
    open(my $fh, '-|', 'git', 'diff', '--cached', '--name-only', '--diff-filter=ACM')
        or die "Cannot run git diff: $!";
    while (my $line = <$fh>) {
        chomp $line;
        if ($line =~ /\.fods$/i) {
            push @files, $line;
        }
    }
    close($fh);
    return @files;
}

# Get HEAD content from git (last committed version)
sub get_head_content {
    my ($file) = @_;
    my $content;
    open(my $fh, '-|', 'git', 'show', 'HEAD:' . $file)
        or return undef;
    {
        local $/;
        $content = <$fh>;
    }
    close($fh);
    return $content;
}

# Read file content
sub read_file {
    my ($file) = @_;
    open(my $fh, '<', $file) or die "Cannot read $file: $!";
    binmode($fh);
    local $/;
    my $content = <$fh>;
    close($fh);
    return $content;
}

# Write file content
sub write_file {
    my ($file, $content) = @_;
    open(my $fh, '>', $file) or die "Cannot write $file: $!";
    binmode($fh);
    print $fh $content;
    close($fh);
}

# Clear office:meta content
sub clear_office_meta {
    my ($xml) = @_;
    $xml =~ s{(<office:meta>).*?(</office:meta>)}{$1$2}gs;
    return $xml;
}

# Clear ooo:configuration-settings content
sub clear_configuration_settings {
    my ($xml) = @_;
    $xml =~ s{(<config:config-item-set\s+config:name="ooo:configuration-settings">).*?(</config:config-item-set>)}{$1$2}gs;
    return $xml;
}

# Remove style:region-right element entirely
sub clear_region_right {
    my ($xml) = @_;
    $xml =~ s{\s*<style:region-right>.*?</style:region-right>\s*}{}gs;
    return $xml;
}

# Parse config items from view-settings section
sub parse_config_items {
    my ($content) = @_;
    my %items;
    
    # Match <config:config-item config:name="..." config:type="...">value</config:config-item>
    while ($content =~ m{<config:config-item\s+config:name="([^"]+)"\s+config:type="([^"]+)"[^>]*>([^<]*)</config:config-item>}gs) {
        my ($name, $type, $value) = ($1, $2, $3);
        $items{$name} = {
            type => $type,
            value => $value,
            full_match => $&
        };
    }
    
    return \%items;
}

# Parse style elements and their child fields from automatic-styles section
# Returns hash: { style_name => { opening_tag => "...", children => { tag_name => element_text } } }
sub parse_automatic_styles_items {
    my ($content) = @_;
    my %items;
    while ($content =~ m{(<(?:style:style|style:page-layout)\s+[^>]*style:name="([^"]+)"[^>]*>)(.*?)(</(?:style:style|style:page-layout)>)}gs) {
        my ($opening, $name, $inner, $closing) = ($1, $2, $3, $4);
        my %children;
        # Parse child elements (non-self-closing)
        while ($inner =~ m{(<style:[^>]+>.*?</style:[^>]+>)}gs) {
            my ($child) = $1;
            my ($child_tag) = $child =~ m{<(style:[^ >/]+)};
            $children{$child_tag} = $child if defined $child_tag;
        }
        # Parse child elements (self-closing)
        while ($inner =~ m{(<style:[^>]+/>)}g) {
            my ($child) = $1;
            my ($child_tag) = $child =~ m{<(style:[^ >/]+)};
            $children{$child_tag} = $child if defined $child_tag;
        }
        $items{$name} = {
            opening => $opening,
            inner => $inner,
            closing => $closing,
            children => \%children,
            full => $opening . $inner . $closing,
        };
    }
    return \%items;
}

# Process automatic-styles: keep adds/deletes, revert child field changes
# Same strategy as view-settings: compare by name, revert changed fields, keep adds/deletes
sub process_automatic_styles {
    my ($head_xml, $working_xml) = @_;
    
    my ($head_section) = $head_xml =~ m{(<office:automatic-styles>.*?</office:automatic-styles>)}gs;
    my ($working_section) = $working_xml =~ m{(<office:automatic-styles>.*?</office:automatic-styles>)}gs;
    
    return $working_xml unless defined $head_section;
    return $working_xml unless defined $working_section;
    
    my $head_items = parse_automatic_styles_items($head_section);
    my $working_items = parse_automatic_styles_items($working_section);
    
    my $result = $working_section;
    
    for my $name (keys %$working_items) {
        if (exists $head_items->{$name}) {
            my $h = $head_items->{$name};
            my $w = $working_items->{$name};
            my $changed = 0;
            
            # Compare child fields: if changed, revert to HEAD version
            # Added children: keep; Deleted children: keep deletion
            my $new_inner = $w->{inner};
            for my $child_tag (keys %{$w->{children}}) {
                if (exists $h->{children}{$child_tag}) {
                    if ($h->{children}{$child_tag} ne $w->{children}{$child_tag}) {
                        # Field changed - revert to HEAD
                        $new_inner =~ s{\Q$w->{children}{$child_tag}\E}{$h->{children}{$child_tag}};
                        $changed = 1;
                    }
                }
                # If only in working: added, keep it
            }
            # If only in HEAD: deleted, keep deletion (don't add back)
            
            if ($changed) {
                my $new_element = $w->{opening} . $new_inner . $w->{closing};
                $result =~ s{\Q$w->{full}\E}{$new_element};
            }
        }
        # If only in working: added, keep it
    }
    # If only in HEAD: deleted, keep deletion
    
    $working_xml =~ s{\Q$working_section\E}{$result};
    return $working_xml;
}

# Process spreadsheet style-names: keep adds/deletes, revert style-name changes
sub process_spreadsheet_style_names {
    my ($head_xml, $working_xml) = @_;
    
    my ($head_section) = $head_xml =~ m{(<office:spreadsheet>.*?</office:spreadsheet>)}gs;
    my ($working_section) = $working_xml =~ m{(<office:spreadsheet>.*?</office:spreadsheet>)}gs;
    
    return $working_xml unless defined $head_section;
    return $working_xml unless defined $working_section;
    
    # Collect elements with style-name from a section
    # Returns array of { full_tag, attr_name, attr_value, fingerprint }
    sub collect_style_elements {
        my ($section) = @_;
        my @elements;
        while ($section =~ m{(<(table:table|table:table-column|table:table-row|table:table-cell)\s+([^>]*?)>)}g) {
            my ($full_tag, $tag_name, $attrs) = ($1, $2, $3);
            # Fingerprint: remove style-name and default-cell-style-name
            my $fp = $attrs;
            $fp =~ s/table:(?:default-cell-)?style-name="[^"]+"//g;
            $fp =~ s/\s+/ /g;
            $fp =~ s/^\s+//;
            $fp =~ s/\s+$//;
            my $fingerprint = "$tag_name $fp";
            # Collect table:style-name
            if ($attrs =~ /table:style-name="([^"]+)"/) {
                push @elements, {
                    full_tag => $full_tag,
                    attr_name => 'table:style-name',
                    attr_value => $1,
                    fingerprint => $fingerprint,
                };
            }
            # Collect table:default-cell-style-name
            if ($attrs =~ /table:default-cell-style-name="([^"]+)"/) {
                push @elements, {
                    full_tag => $full_tag,
                    attr_name => 'table:default-cell-style-name',
                    attr_value => $1,
                    fingerprint => $fingerprint,
                };
            }
        }
        return @elements;
    }
    
    my @head_elements = collect_style_elements($head_section);
    my @working_elements = collect_style_elements($working_section);
    
    # Build ordered lookup from HEAD: fingerprint => [ { attr_name, attr_value } ]
    my %head_lookup;
    for my $elem (@head_elements) {
        push @{$head_lookup{$elem->{fingerprint}}}, { $elem->{attr_name} => $elem->{attr_value} };
    }
    
    # Track consumed index per fingerprint
    my %consumed;
    my $result = $working_section;
    
    for my $i (0..$#working_elements) {
        my $wp = $working_elements[$i];
        my $fp = $wp->{fingerprint};
        if (exists $head_lookup{$fp}) {
            my $idx = $consumed{$fp} // 0;
            if ($idx < @{$head_lookup{$fp}}) {
                my $head_entry = $head_lookup{$fp}[$idx];
                if (exists $head_entry->{$wp->{attr_name}}) {
                    my $head_val = $head_entry->{$wp->{attr_name}};
                    if ($head_val ne $wp->{attr_value}) {
                        my $old = $wp->{full_tag};
                        my $new = $old;
                        $new =~ s{(\Q$wp->{attr_name}\E=")[^"]+"}{$1$head_val"};
                        $result =~ s{\Q$old\E}{$new};
                    }
                }
                $consumed{$fp} = $idx + 1;
            }
        }
    }
    
    $working_xml =~ s{\Q$working_section\E}{$result};
    return $working_xml;
}

# Process view-settings: keep adds/deletes, revert value changes
sub process_view_settings {
    my ($head_xml, $working_xml) = @_;
    
    # Extract view-settings sections
    my ($head_section) = $head_xml =~ m{(<config:config-item-set\s+config:name="ooo:view-settings">.*?</config:config-item-set>)}gs;
    my ($working_section) = $working_xml =~ m{(<config:config-item-set\s+config:name="ooo:view-settings">.*?</config:config-item-set>)}gs;
    
    # If no HEAD version, return working version as-is (it's a new file)
    return $working_xml unless defined $head_section;
    
    # If no working version, something's wrong
    return $working_xml unless defined $working_section;
    
    # Parse items from both versions
    my $head_items = parse_config_items($head_section);
    my $working_items = parse_config_items($working_section);
    
    # Build merged items:
    # - If item exists in both but value changed: use HEAD value
    # - If item exists only in HEAD: it was deleted, skip it (preserve delete)
    # - If item exists only in working: it was added, use working value (preserve add)
    # - If item exists in both and value same: use working value
    
    my %merged_items;
    
    # Process items that exist in working version
    for my $name (keys %$working_items) {
        if (exists $head_items->{$name}) {
            # Item exists in both - check if value changed
            if ($head_items->{$name}{value} ne $working_items->{$name}{value}) {
                # Value changed - revert to HEAD
                $merged_items{$name} = $head_items->{$name};
            } else {
                # Value same - keep working version
                $merged_items{$name} = $working_items->{$name};
            }
        } else {
            # Item only in working - it was added, keep it
            $merged_items{$name} = $working_items->{$name};
        }
    }
    
    # Note: We don't add items that are only in HEAD (they were deleted)
    
    # Rebuild the view-settings section with merged items
    # We need to preserve the structure and order as much as possible
    # For simplicity, we'll rebuild just the config-item parts
    
    # Find the opening tag
    my ($opening_tag) = $working_section =~ m{(<config:config-item-set\s+config:name="ooo:view-settings"[^>]*>)};
    
    # Find the closing tag
    my $closing_tag = '</config:config-item-set>';
    
    # Rebuild config items in the order they appear in working version
    my $new_items = '';
    my $current_section = $working_section;
    
    # We need to handle nested structures properly
    # For now, use a simpler approach: replace each config-item value
    
    # This is a simplified version - it handles flat config-items but not nested maps
    # For nested structures like Views/Tables, we need more complex handling
    
    # Let's try a different approach: walk through the working section
    # and replace individual config-item values where needed
    
    my $result = $working_section;
    
    for my $name (keys %$working_items) {
        if (exists $head_items->{$name}) {
            if ($head_items->{$name}{value} ne $working_items->{$name}{value}) {
                # Value changed - replace with HEAD value
                my $old_item = $working_items->{$name}{full_match};
                my $new_item = $old_item;
                $new_item =~ s{>.*?</config:config-item>}{>$head_items->{$name}{value}</config:config-item>};
                $result =~ s{\Q$old_item\E}{$new_item};
            }
        }
    }
    
    # Replace the view-settings section in the XML
    $working_xml =~ s{\Q$working_section\E}{$result};
    
    return $working_xml;
}

# Process a single FODS file
sub process_fods_file {
    my ($file) = @_;
    
    # Get HEAD content (last committed version)
    my $head_content = get_head_content($file);
    
    # Read working directory content
    my $working_content = read_file($file);
    
    # If no HEAD content, this is a new file - just clean meta and region-right
    unless (defined $head_content) {
        $working_content = clear_office_meta($working_content);
        $working_content = clear_configuration_settings($working_content);
        $working_content = clear_region_right($working_content);
        write_file($file, $working_content);
        return;
    }
    
    # Process view-settings (merge changes)
    $working_content = process_view_settings($head_content, $working_content);
    
    # Process automatic-styles (merge changes)
    $working_content = process_automatic_styles($head_content, $working_content);
    
    # Process spreadsheet style-names (merge changes)
    $working_content = process_spreadsheet_style_names($head_content, $working_content);
    
    # Clear office:meta
    $working_content = clear_office_meta($working_content);
    
    # Clear ooo:configuration-settings
    $working_content = clear_configuration_settings($working_content);
    
    # Clear style:region-right
    $working_content = clear_region_right($working_content);
    
    # Write back to working directory
    write_file($file, $working_content);
}

# Main entry point
sub main {
    my @files = get_staged_fods_files();
    
    return unless @files;
    
    for my $file (@files) {
        process_fods_file($file);
    }
    
    # Re-add modified files to staging area
    system('git', 'add', @files) == 0
        or die "Failed to re-add files to staging area";
}

main();
